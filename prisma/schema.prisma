// Tsystem1 集中資料庫結構 - Prisma Schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===== 1. User 使用者帳戶表 =====
model User {
  id            String    @id @default(cuid())
  username      String    @unique
  password      String
  role          UserRole  @default(STAFF)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // 關聯
  transactions  Transaction[]
  shiftLogs     ShiftLog[]
  
  @@map("users")
}

// ===== 2. Member 會員/客戶表 =====
model Member {
  id            String    @id @default(cuid())
  name          String
  phone         String?
  balance       Float     @default(0)
  creditLimit   Float     @default(0)
  currentDebt   Float     @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // 關聯
  transactions  Transaction[]
  
  @@map("members")
}

// ===== 3. Transaction 交易記錄表 =====
model Transaction {
  id            String    @id @default(cuid())
  memberId      String
  member        Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)
  
  type          TransactionType
  amount        Float
  
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  shiftId       String?
  shiftLog      ShiftLog? @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  @@index([memberId])
  @@index([userId])
  @@index([shiftId])
  @@map("transactions")
}

// ===== 4. ShiftLog 班次記錄表 =====
model ShiftLog {
  id            String    @id @default(cuid())
  managerId     String
  manager       User      @relation(fields: [managerId], references: [id], onDelete: Cascade)
  
  expectedCash  Float     @default(0)
  actualCash    Float     @default(0)
  discrepancy   Float     @default(0)
  isClosed      Boolean   @default(false)
  
  createdAt     DateTime  @default(now())
  closedAt      DateTime?
  
  // 關聯
  transactions  Transaction[]
  
  @@index([managerId])
  @@map("shift_logs")
}

// ===== 5. SystemConfig 系統配置表 =====
model SystemConfig {
  id            String    @id @default(cuid())
  key           String    @unique
  value         Json      // 存儲 JSON 格式的配置值
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  @@map("system_configs")
}

// ===== 列舉定義 =====
enum UserRole {
  STAFF           // 基層員工（可進行交易）
  MANAGER         // 經理（可結班）
  ADMIN           // 管理員（全權限）
}

enum TransactionType {
  CASH_BUY_IN    // 現金買入
  CREDIT_SIGN_IN // 信用簽帳
  CASH_OUT       // 現金取出
  DEBT_REPAY     // 債務還款
  VAULT_IN       // 金庫進帳
  VAULT_OUT      // 金庫出帳
  DEPOSIT        // 存款
  WITHDRAWAL     // 提款
}

